<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gg.goods.mapper.BookMapper">
    <resultMap id="BaseResultMap" type="com.gg.goods.entity.Book">
        <id property="bid" column="bid" jdbcType="CHAR"/>
        <result property="bname" column="bname" jdbcType="VARCHAR"/>
        <result property="author" column="author" jdbcType="VARCHAR"/>
        <result property="price" column="price" jdbcType="DECIMAL"/>
        <result property="currprice" column="currPrice" jdbcType="DECIMAL"/>
        <result property="discount" column="discount" jdbcType="DECIMAL"/>
        <result property="press" column="press" jdbcType="VARCHAR"/>
        <result property="publishtime" column="publishtime" jdbcType="CHAR"/>
        <result property="edition" column="edition" jdbcType="INTEGER"/>
        <result property="pagenum" column="pageNum" jdbcType="INTEGER"/>
        <result property="wordnum" column="wordNum" jdbcType="INTEGER"/>
        <result property="printtime" column="printtime" jdbcType="CHAR"/>
        <result property="booksize" column="booksize" jdbcType="INTEGER"/>
        <result property="paper" column="paper" jdbcType="VARCHAR"/>
        <result property="cid" column="cid" jdbcType="CHAR"/>
        <result property="imageW" column="image_w" jdbcType="VARCHAR"/>
        <result property="imageB" column="image_b" jdbcType="VARCHAR"/>
        <result property="shunxu" column="shunxu" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        bid,bname,author,
        price,currPrice,discount,
        press,publishtime,edition,
        pageNum,wordNum,printtime,
        booksize,paper,cid,
        image_w,image_b,shunxu
    </sql>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from book
        where bid = #{bid,jdbcType=CHAR}
    </select>

    <!--查询多本-->
    <!-- and author like concat('%',#{author},'%')-->
    <select id="selectBooksByCase" resultType="com.gg.goods.entity.Book">
        select * from book
        <where>
            <if test="cid!=null and cid!=''">
                cid = #{cid}
            </if>
            <if test="author!=null and author!=''">
                and author=#{author}
            </if>
            <if test="press!=null and  press!=''">
                and press= #{press}
            </if>
            <if test="bname!=null and bname!=''">
                and bname like concat('%',#{bname},'%')
            </if>
        </where>
    </select>

    <delete id="deleteByPrimaryKey" parameterType="java.lang.Long">
        delete
        from book
        where bid = #{bid,jdbcType=CHAR}
    </delete>
    <insert id="insert" keyColumn="bid" keyProperty="bid" parameterType="com.gg.goods.entity.Book"
            useGeneratedKeys="true">
        insert into book
        ( bid, bname, author
        , price, currPrice, discount
        , press, publishtime, edition
        , pageNum, wordNum, printtime
        , booksize, paper, cid
        , image_w, image_b, shunxu)
        values ( #{bid,jdbcType=CHAR}, #{bname,jdbcType=VARCHAR}, #{author,jdbcType=VARCHAR}
               , #{price,jdbcType=DECIMAL}, #{currprice,jdbcType=DECIMAL}, #{discount,jdbcType=DECIMAL}
               , #{press,jdbcType=VARCHAR}, #{publishtime,jdbcType=CHAR}, #{edition,jdbcType=INTEGER}
               , #{pagenum,jdbcType=INTEGER}, #{wordnum,jdbcType=INTEGER}, #{printtime,jdbcType=CHAR}
               , #{booksize,jdbcType=INTEGER}, #{paper,jdbcType=VARCHAR}, #{cid,jdbcType=CHAR}
               , #{imageW,jdbcType=VARCHAR}, #{imageB,jdbcType=VARCHAR}, #{shunxu,jdbcType=INTEGER})
    </insert>
    <insert id="insertSelective" keyColumn="bid" keyProperty="bid" parameterType="com.gg.goods.entity.Book"
            useGeneratedKeys="true">
        insert into book
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="bid != null">
                bid,
            </if>
            <if test="bname != null">
                bname,
            </if>
            <if test="author != null">
                author,
            </if>
            <if test="price != null">
                price,
            </if>
            <if test="currprice != null">
                currPrice,
            </if>
            <if test="discount != null">
                discount,
            </if>
            <if test="press != null">
                press,
            </if>
            <if test="publishtime != null">
                publishtime,
            </if>
            <if test="edition != null">
                edition,
            </if>
            <if test="pagenum != null">
                pageNum,
            </if>
            <if test="wordnum != null">
                wordNum,
            </if>
            <if test="printtime != null">
                printtime,
            </if>
            <if test="booksize != null">
                booksize,
            </if>
            <if test="paper != null">
                paper,
            </if>
            <if test="cid != null">
                cid,
            </if>
            <if test="imageW != null">
                image_w,
            </if>
            <if test="imageB != null">
                image_b,
            </if>
            <if test="shunxu != null">
                shunxu,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="bid != null">
                #{bid,jdbcType=CHAR},
            </if>
            <if test="bname != null">
                #{bname,jdbcType=VARCHAR},
            </if>
            <if test="author != null">
                #{author,jdbcType=VARCHAR},
            </if>
            <if test="price != null">
                #{price,jdbcType=DECIMAL},
            </if>
            <if test="currprice != null">
                #{currprice,jdbcType=DECIMAL},
            </if>
            <if test="discount != null">
                #{discount,jdbcType=DECIMAL},
            </if>
            <if test="press != null">
                #{press,jdbcType=VARCHAR},
            </if>
            <if test="publishtime != null">
                #{publishtime,jdbcType=CHAR},
            </if>
            <if test="edition != null">
                #{edition,jdbcType=INTEGER},
            </if>
            <if test="pagenum != null">
                #{pagenum,jdbcType=INTEGER},
            </if>
            <if test="wordnum != null">
                #{wordnum,jdbcType=INTEGER},
            </if>
            <if test="printtime != null">
                #{printtime,jdbcType=CHAR},
            </if>
            <if test="booksize != null">
                #{booksize,jdbcType=INTEGER},
            </if>
            <if test="paper != null">
                #{paper,jdbcType=VARCHAR},
            </if>
            <if test="cid != null">
                #{cid,jdbcType=CHAR},
            </if>
            <if test="imageW != null">
                #{imageW,jdbcType=VARCHAR},
            </if>
            <if test="imageB != null">
                #{imageB,jdbcType=VARCHAR},
            </if>
            <if test="shunxu != null">
                #{shunxu,jdbcType=INTEGER},
            </if>
        </trim>
    </insert>
    <update id="updateByPrimaryKeySelective" parameterType="com.gg.goods.entity.Book">
        update book
        <set>
            <if test="bname != null">
                bname = #{bname,jdbcType=VARCHAR},
            </if>
            <if test="author != null">
                author = #{author,jdbcType=VARCHAR},
            </if>
            <if test="price != null">
                price = #{price,jdbcType=DECIMAL},
            </if>
            <if test="currprice != null">
                currPrice = #{currprice,jdbcType=DECIMAL},
            </if>
            <if test="discount != null">
                discount = #{discount,jdbcType=DECIMAL},
            </if>
            <if test="press != null">
                press = #{press,jdbcType=VARCHAR},
            </if>
            <if test="publishtime != null">
                publishtime = #{publishtime,jdbcType=CHAR},
            </if>
            <if test="edition != null">
                edition = #{edition,jdbcType=INTEGER},
            </if>
            <if test="pagenum != null">
                pageNum = #{pagenum,jdbcType=INTEGER},
            </if>
            <if test="wordnum != null">
                wordNum = #{wordnum,jdbcType=INTEGER},
            </if>
            <if test="printtime != null">
                printtime = #{printtime,jdbcType=CHAR},
            </if>
            <if test="booksize != null">
                booksize = #{booksize,jdbcType=INTEGER},
            </if>
            <if test="paper != null">
                paper = #{paper,jdbcType=VARCHAR},
            </if>
            <if test="cid != null">
                cid = #{cid,jdbcType=CHAR},
            </if>
            <if test="imageW != null">
                image_w = #{imageW,jdbcType=VARCHAR},
            </if>
            <if test="imageB != null">
                image_b = #{imageB,jdbcType=VARCHAR},
            </if>
            <if test="shunxu != null">
                shunxu = #{shunxu,jdbcType=INTEGER},
            </if>
        </set>
        where bid = #{bid,jdbcType=CHAR}
    </update>

    <!--查询热门图书（按销量或浏览量排序）-->
    <select id="selectHotBooks" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from book
        order by shunxu desc
        limit #{limit,jdbcType=INTEGER}
    </select>

    <!--根据分类ID查询图书-->
    <select id="selectBooksByCid" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from book
        where cid = #{cid,jdbcType=CHAR}
    </select>

    <!--根据书名模糊查询-->
    <select id="selectBooksByBname" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from book
        where bname like concat('%',#{bname,jdbcType=VARCHAR},'%')
    </select>

    <!--根据作者查询图书-->
    <select id="selectBooksByAuthor" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from book
        where author = #{author,jdbcType=VARCHAR}
    </select>

    <!--根据出版社查询图书-->
    <select id="selectBooksByPress" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from book
        where press = #{press,jdbcType=VARCHAR}
    </select>

    <!--查询最新上架的图书-->
    <select id="selectNewestBooks" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from book
        order by publishtime desc
        limit #{limit,jdbcType=INTEGER}
    </select>

    <!--批量查询图书信息-->
    <select id="selectBooksByBids" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from book
        where bid in
        <foreach collection="list" item="bid" open="(" separator="," close=")">
            #{bid,jdbcType=CHAR}
        </foreach>
    </select>

    <!--更新图书的销量或浏览量-->
    <update id="updateBookStatistics" parameterType="java.util.Map">
        update book
        set
        <if test="type == 'sales'">
            sales = sales + #{value,jdbcType=INTEGER}
        </if>
        <if test="type == 'views'">
            views = views + #{value,jdbcType=INTEGER}
        </if>
        where bid = #{bid,jdbcType=CHAR}
    </update>

    <!--查询图书总数-->
    <select id="selectBookCount" resultType="java.lang.Integer">
        select count(*)
        from book
        <where>
            <if test="cid != null and cid != ''">
                cid = #{cid,jdbcType=CHAR}
            </if>
            <if test="bname != null and bname != ''">
                and bname like concat('%',#{bname,jdbcType=VARCHAR},'%')
            </if>
            <if test="author != null and author != ''">
                and author = #{author,jdbcType=VARCHAR}
            </if>
            <if test="press != null and press != ''">
                and press = #{press,jdbcType=VARCHAR}
            </if>
        </where>
    </select>
</mapper>
