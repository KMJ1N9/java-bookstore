<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gg.goods.mapper.CartitemMapper">
    <resultMap id="BaseResultMap" type="com.gg.goods.entity.Cartitem">
        <id column="cartitemid" property="cartitemid" jdbcType="VARCHAR"/>
        <result column="quantity" property="quantity" jdbcType="INTEGER"/>
        <result column="bid" property="bid" jdbcType="VARCHAR"/>
        <result column="uid" property="uid" jdbcType="VARCHAR"/>
        <result column="shunxu" property="shunxu" jdbcType="INTEGER"/>
    </resultMap>

    <resultMap id="BookResultMap" type="com.gg.goods.entity.Book">
        <id column="book_bid" property="bid" jdbcType="VARCHAR"/>
        <result column="bname" property="bname" jdbcType="VARCHAR"/>
        <result column="author" property="author" jdbcType="VARCHAR"/>
        <result column="price" property="price" jdbcType="DECIMAL"/>
        <result column="currPrice" property="currprice" jdbcType="DECIMAL"/>
        <result column="discount" property="discount" jdbcType="DECIMAL"/>
        <result column="image_b" property="imageB" jdbcType="VARCHAR"/>
    </resultMap>

    <resultMap id="CartBookPovoMap" type="com.gg.goods.povos.CartBookPovo">
        <association property="cartitem" resultMap="BaseResultMap"/>
        <association property="book" resultMap="BookResultMap"/>
    </resultMap>

    <sql id="Base_Column_List">
        cartitemid, quantity, bid, uid, shunxu
    </sql>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap" parameterType="java.lang.String">
        select
        <include refid="Base_Column_List"/>
        from cartitem
        where cartitemid = #{cartitemid,jdbcType=VARCHAR}
    </select>

    <delete id="deleteByPrimaryKey" parameterType="java.lang.String">
        delete
        from cartitem
        where cartitemid = #{cartitemid,jdbcType=VARCHAR}
    </delete>

    <insert id="insert" parameterType="com.gg.goods.entity.Cartitem">
        insert into cartitem (cartitemid, quantity, bid, uid, shunxu)
        values (#{cartitemid,jdbcType=VARCHAR}, #{quantity,jdbcType=INTEGER}, #{bid,jdbcType=VARCHAR},
                #{uid,jdbcType=VARCHAR}, #{shunxu,jdbcType=INTEGER})
    </insert>

    <insert id="insertSelective" parameterType="com.gg.goods.entity.Cartitem">
        insert into cartitem
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cartitemid != null">
                cartitemid,
            </if>
            <if test="quantity != null">
                quantity,
            </if>
            <if test="bid != null">
                bid,
            </if>
            <if test="uid != null">
                uid,
            </if>
            <if test="shunxu != null">
                shunxu,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="cartitemid != null">
                #{cartitemid,jdbcType=VARCHAR},
            </if>
            <if test="quantity != null">
                #{quantity,jdbcType=INTEGER},
            </if>
            <if test="bid != null">
                #{bid,jdbcType=VARCHAR},
            </if>
            <if test="uid != null">
                #{uid,jdbcType=VARCHAR},
            </if>
            <if test="shunxu != null">
                #{shunxu,jdbcType=INTEGER},
            </if>
        </trim>
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="com.gg.goods.entity.Cartitem">
        update cartitem
        <set>
            <if test="quantity != null">
                quantity = #{quantity,jdbcType=INTEGER},
            </if>
            <if test="bid != null">
                bid = #{bid,jdbcType=VARCHAR},
            </if>
            <if test="uid != null">
                uid = #{uid,jdbcType=VARCHAR},
            </if>
            <if test="shunxu != null">
                shunxu = #{shunxu,jdbcType=INTEGER},
            </if>
        </set>
        where cartitemid = #{cartitemid,jdbcType=VARCHAR}
    </update>

    <update id="updateByPrimaryKey" parameterType="com.gg.goods.entity.Cartitem">
        update cartitem
        set quantity = #{quantity,jdbcType=INTEGER},
            bid      = #{bid,jdbcType=VARCHAR},
            uid      = #{uid,jdbcType=VARCHAR},
            shunxu   = #{shunxu,jdbcType=INTEGER}
        where cartitemid = #{cartitemid,jdbcType=VARCHAR}
    </update>

    <!-- 查询用户的所有购物车项及其图书信息 -->
    <select id="selectCartitemBookByUid" resultMap="CartBookPovoMap">
        SELECT ci.cartitemid,
               ci.quantity,
               ci.bid,
               ci.uid,
               ci.shunxu,
               b.bid as book_bid,
               b.bname,
               b.author,
               b.price,
               b.currPrice,
               b.discount,
               b.image_b
        FROM cartitem ci
                 LEFT JOIN book b ON ci.bid = b.bid
        WHERE ci.uid = #{uid,jdbcType=VARCHAR}
        ORDER BY ci.shunxu DESC
    </select>

    <!-- 根据用户ID和图书ID查询购物车项 -->
    <select id="selectCartitemByUidAndBid" resultMap="BaseResultMap" parameterType="com.gg.goods.entity.Cartitem">
        select
        <include refid="Base_Column_List"/>
        from cartitem
        where uid = #{uid,jdbcType=VARCHAR}
        and bid = #{bid,jdbcType=VARCHAR}
    </select>

    <!-- 根据cartitemid删除购物车项 -->
    <delete id="removeCartItem" parameterType="java.lang.String">
        delete
        from cartitem
        where cartitemid = #{cartitemid,jdbcType=VARCHAR}
    </delete>

    <!-- 批量删除购物车项 -->
    <delete id="batchRemoveCartItems" parameterType="java.util.List">
        delete from cartitem
        where cartitemid in
        <foreach collection="list" item="cartitemid" open="(" close=")" separator=",">
            #{cartitemid,jdbcType=VARCHAR}
        </foreach>
    </delete>

    <!-- 根据用户ID清空购物车 -->
    <delete id="clearCartByUserId" parameterType="java.lang.String">
        delete
        from cartitem
        where uid = #{uid,jdbcType=VARCHAR}
    </delete>

    <!-- 更新购物车项数量 -->
    <update id="updateCartItemQuantity" parameterType="com.gg.goods.entity.Cartitem">
        update cartitem
        set quantity = #{quantity,jdbcType=INTEGER}
        where cartitemid = #{cartitemid,jdbcType=VARCHAR}
    </update>

    <!-- 根据购物车项ID列表查询购物车项和图书信息 -->
    <select id="selectCartitemBookByIds" parameterType="java.util.List" resultMap="CartBookPovoMap">
        SELECT
        ci.cartitemid,
        ci.quantity,
        ci.bid,
        ci.uid,
        ci.shunxu,
        b.bid as book_bid,
        b.bname,
        b.author,
        b.price,
        b.currPrice,
        b.discount,
        b.image_b
        FROM cartitem ci
        LEFT JOIN book b ON ci.bid = b.bid
        WHERE ci.cartitemid in
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id,jdbcType=VARCHAR}
        </foreach>
    </select>
</mapper>